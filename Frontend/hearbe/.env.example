# ============================================================================
# Backend API (로컬 개발 시 Backend docker compose의 COMPOSE_HOST_PORT와 일치시킬 것)
# ============================================================================
VITE_API_BASE_URL=http://localhost:8080

# ============================================================================
# OCR AI 서버 URL (복지카드 인식 API, AI 서버 미사용 시 빈 값 가능)
# ============================================================================
VITE_OCR_WELFARE_CARD_URL=https://your-ai-domain/api/v1/ocr/welfare-card

# ============================================================================
# EmailJS 설정 (https://www.emailjs.com 에서 발급)
# ============================================================================
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

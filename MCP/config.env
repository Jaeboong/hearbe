# MCP 데스크탑 앱 환경 변수 예시
# .env 파일을 생성하고 이 내용을 복사하여 실제 값으로 수정하세요

# ============================================================================
# Home (홈 URL 설정)
# ============================================================================
# Base home URL for the application
HOME_URL=https://i14d108.p.ssafy.io/main?app=mcp

# ============================================================================
# Network (네트워크 설정)
# ============================================================================
# WebSocket 서버 URL
WS_URL=wss://www.jhserver.shop/ws

# 인증 서버 URL
AUTH_URL=https://www.jhserver.shop/auth




# 재연결 시도 간격 (초)
WS_RECONNECT_DELAY=5

# 최대 재연결 시도 횟수
WS_MAX_RETRIES=10

# ============================================================================
# Audio (오디오 설정)
# ============================================================================
# 샘플링 레이트 (Hz)
AUDIO_SAMPLE_RATE=16000

# 채널 수 (1=모노, 2=스테레오)
AUDIO_CHANNELS=1

# 버퍼 크기 (프레임 수)
AUDIO_CHUNK_SIZE=1024

# 녹음 시작 핫키
HOTKEY=space

# ============================================================================
# Browser (브라우저 설정)
# ============================================================================
# Debug 모드
DEBUG_CONSOLE_ENABLED=false

# Chrome 실행 파일 경로 (비어있으면 자동 탐지)
BROWSER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Chrome DevTools Protocol 포트
BROWSER_CDP_PORT=9222

# Chrome 사용자 데이터 디렉토리
BROWSER_USER_DATA_DIR=.mcp_chrome_profile

# 헤드리스 모드 (true/false)
BROWSER_HEADLESS=false

# 브라우저 창 크기
BROWSER_WINDOW_WIDTH=1280
BROWSER_WINDOW_HEIGHT=720

# ============================================================================
# MCP (Model Context Protocol 설정)
# ============================================================================
# MCP 서버 스크립트 경로
MCP_SERVER_COMMAND=python mcp/playwright_mcp_server.py

# Python 실행 파일 경로 (비어있으면 시스템 python 사용)
PYTHON_PATH=

# MCP 서버 시작 타임아웃 (초)
MCP_SERVER_TIMEOUT=30

# ============================================================================
# Logging (로깅 설정)
# ============================================================================
# 로그 레벨 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 로그 디렉토리
LOG_FILE_PATH=logs/app.log

# 로그 파일 최대 크기 (바이트)
LOG_MAX_BYTES=10485760

# 로그 백업 파일 개수
LOG_BACKUP_COUNT=5

# ============================================================================
# Session (세션 설정)
# ============================================================================
# 세션 저장 파일
SESSION_FILE_PATH=session.json



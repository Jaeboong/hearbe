# MCP 데스크탑 앱 환경 변수 예시
# .env 파일을 생성하고 이 내용을 복사하여 실제 값으로 수정하세요

# ============================================================================
# Network (네트워크 설정)
# ============================================================================
# WebSocket 서버 URL
WS_URL=ws://localhost:8000/ws

# 재연결 대기 시간 (초)
WS_RECONNECT_DELAY=5

# 최대 재연결 시도 횟수 (-1: 무한)
WS_MAX_RETRIES=10

# ============================================================================
# Audio (오디오 설정)
# ============================================================================
# 샘플링 레이트 (Hz)
AUDIO_SAMPLE_RATE=16000

# 채널 수 (1=모노, 2=스테레오)
AUDIO_CHANNELS=1

# 버퍼 크기 (프레임 수)
AUDIO_CHUNK_SIZE=1024

# 녹음 시작 핫키
HOTKEY=v

# ============================================================================
# Browser (브라우저 설정)
# ============================================================================
# Chrome 실행 파일 경로 (비어있으면 자동 탐지)
BROWSER_EXECUTABLE_PATH=

# Chrome DevTools Protocol 포트
BROWSER_CDP_PORT=9222

# Chrome 사용자 데이터 디렉토리
BROWSER_USER_DATA_DIR=./chrome_profile

# 헤드리스 모드 (true/false)
BROWSER_HEADLESS=false

# ============================================================================
# MCP (Model Context Protocol 설정)
# ============================================================================
# MCP 서버 실행 명령어
MCP_SERVER_COMMAND=python mcp/playwright_mcp_server.py

# MCP 서버 시작 타임아웃 (초)
MCP_SERVER_TIMEOUT=10

# MCP 도구 실행 타임아웃 (초)
MCP_TOOL_TIMEOUT=60

# ============================================================================
# Session (세션 설정)
# ============================================================================
# 세션 저장 파일 경로
SESSION_FILE_PATH=./session.json

# 세션 자동 저장 여부
SESSION_AUTO_SAVE=true

# ============================================================================
# Logging (로깅 설정)
# ============================================================================
# 로그 레벨 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 로그 파일 경로
LOG_FILE_PATH=./logs/app.log

# ============================================================================
# Debug (디버그 설정)
# ============================================================================
# 콘솔 입력 모드 활성화 (테스트용)
DEBUG_CONSOLE_ENABLED=false

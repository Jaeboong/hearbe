# Local overrides for MCP scripted-input tests.
#
# 1) Copy this file to: mcp_scripted_input.local.env
# 2) Edit values to your preference (this file is git-ignored)
#
# You can also override per-run via:
#   .\scripts\run_mcp_scripted_input.ps1 -DelayMs 8000 -InputFile scripted_input_login.txt

# Relative paths are resolved relative to this launcher folder (AI\scripts) first,
# then fall back to: C:\ssafy\공통\MCP\debug
DEBUG_SCRIPTED_INPUT_FILE=scripted_input.txt

# Delay between lines (milliseconds)
DEBUG_SCRIPTED_INPUT_DELAY_MS=12000

# Initial delay before sending the first line (milliseconds)
DEBUG_SCRIPTED_INPUT_START_DELAY_MS=3000

# AI Server 환경 변수 설정
# 이 파일을 .env로 복사 후 실제 값을 입력하세요

# ============================================================================
# 서버 설정
# ============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
WS_PATH=/ws
CORS_ORIGINS=*
DEBUG=false

# ============================================================================
# ASR (음성 인식) 설정
# ============================================================================
# Faster-Whisper 모델
# 옵션: tiny, base, small, medium, large-v2, large-v3, large-v3-turbo
ASR_MODEL_NAME=large-v3-turbo
# 디바이스: cuda, cpu
ASR_DEVICE=cuda
# 연산 타입: float16, float32, int8
ASR_COMPUTE_TYPE=float16
# 언어
ASR_LANGUAGE=ko
# 빔 서치 크기
ASR_BEAM_SIZE=5

# ============================================================================
# NLU (자연어 이해) 설정
# ============================================================================
NLU_INTENT_MODEL=gpt-4o-mini
NLU_NER_ENABLED=true
NLU_CONTEXT_WINDOW=10

# ============================================================================
# LLM Planner 설정
# ============================================================================
LLM_MODEL_NAME=gpt-4o-mini
OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=30

# ============================================================================
# TTS (음성 합성) 설정
# ============================================================================
# 프로바이더: elevenlabs, minimax, cartesia, cosyvoice
TTS_PROVIDER=elevenlabs

# ElevenLabs 설정
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
TTS_VOICE_ID=korean_female_1
TTS_MODEL_ID=eleven_flash_v2_5

# MiniMax 설정 (대안)
# MINIMAX_API_KEY=your-minimax-api-key-here

# Cartesia 설정 (대안)
# CARTESIA_API_KEY=your-cartesia-api-key-here

TTS_SAMPLE_RATE=24000
TTS_STREAMING=true

# ============================================================================
# OCR (이미지 인식) 설정
# ============================================================================
# 프로바이더: openai, tesseract, paddleocr
OCR_PROVIDER=openai
# OpenAI Vision API 사용 시 OPENAI_API_KEY 공유
OCR_LANGUAGE=kor+eng

# ============================================================================
# Flow Engine 설정
# ============================================================================
FLOWS_DIR=flows
DEFAULT_SITE=coupang
FLOW_CONFIRMATION_REQUIRED=true

# ============================================================================
# 로깅 설정
# ============================================================================
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=ai_server.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
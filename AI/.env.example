# AI Server 환경 변수 설정
# 이 파일을 .env로 복사 후 실제 값을 입력하세요

# ============================================================================
# 서버 설정
# ============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=false

# ============================================================================
# ASR (음성 인식) 설정 - Faster-Whisper
# ============================================================================
# 모델: tiny, base, small, medium, large-v2, large-v3, turbo
ASR_MODEL_NAME=turbo
# 디바이스: cuda, cpu
ASR_DEVICE=cuda
# 연산 타입: float16, float32, int8 (VRAM 절약 시 int8)
ASR_COMPUTE_TYPE=float16
ASR_LANGUAGE=ko
ASR_BEAM_SIZE=5

# ============================================================================
# OCR 설정 - PaddleOCR
# ============================================================================
# 프로바이더: paddleocr, openai, tesseract
OCR_PROVIDER=paddleocr
OCR_LANGUAGE=korean

# ============================================================================
# LLM 설정 - SSAFY GMS API (OpenAI 호환)
# ============================================================================
LLM_MODEL_NAME=gpt-5o-mini
OPENAI_API_KEY=sk-your-openai-api-key-here
GMS_API_KEY=example
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=30

# ============================================================================
# TTS (음성 합성) 설정
# ============================================================================
# 프로바이더: elevenlabs, minimax, cartesia, cosyvoice
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
TTS_VOICE_ID=korean_female_1
TTS_SAMPLE_RATE=24000
TTS_STREAMING=true

# ============================================================================
# Flow Engine 설정
# ============================================================================
FLOWS_DIR=flows
DEFAULT_SITE=coupang
FLOW_CONFIRMATION_REQUIRED=true

# ============================================================================
# 로깅 설정
# ============================================================================
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=ai_server.log

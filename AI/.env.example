# AI Server 환경 변수 설정
# 이 파일을 .env로 복사 후 실제 값을 입력하세요

# ============================================================================
# 서버 설정
# ============================================================================
APP_ENV=dev
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=false
# External URL for clients (optional)
# PUBLIC_BASE_URL=https://www.jhserver.shop
# PUBLIC_WS_URL=wss://www.jhserver.shop/ws

# ============================================================================
# ASR (음성 인식) 설정
# ============================================================================
# Provider 선택: whisper (Faster-Whisper) | qwen3 (Qwen3-ASR)
ASR_PROVIDER=whisper
ASR_DEVICE=cuda
ASR_LANGUAGE=ko

# --- Whisper 전용 설정 (ASR_PROVIDER=whisper) ---
# 모델: tiny, base, small, medium, large-v2, large-v3, turbo
ASR_MODEL_NAME=turbo
# 연산 타입: float16, float32, int8 (VRAM 절약 시 int8)
ASR_COMPUTE_TYPE=float16
ASR_BEAM_SIZE=5

# --- Qwen3-ASR 전용 설정 (ASR_PROVIDER=qwen3) ---
# 모델: Qwen/Qwen3-ASR-0.6B (2GB VRAM), Qwen/Qwen3-ASR-1.7B (5GB VRAM)
ASR_QWEN3_MODEL_NAME=Qwen/Qwen3-ASR-0.6B
ASR_QWEN3_MAX_BATCH_SIZE=32
ASR_QWEN3_MAX_NEW_TOKENS=256

# ============================================================================
# OCR 설정 - PaddleOCR
# ============================================================================
# 프로바이더: paddleocr, openai, tesseract
OCR_PROVIDER=paddleocr
OCR_LANGUAGE=korean

# ============================================================================
# LLM Planner 설정
# ============================================================================
LLM_MODEL_NAME=gpt-5-mini
# LLM API 키 선택 (예: OPENAI_API_KEY, GMS_API_KEY)
LLM_API_KEY_NAME=OPENAI_API_KEY
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
GMS_API_KEY=sp-your-gms-api-key-here
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=30
LLM_DEBUG_LOG=false

# ============================================================================
# TTS (음성 합성) 설정 - Google Cloud TTS
# ============================================================================
TTS_SAMPLE_RATE=24000
TTS_STREAMING=true

# Google Cloud TTS 설정
# 서비스 계정 JSON 파일 경로
GOOGLE_APPLICATION_CREDENTIALS=config/google-service-account.json
# 음성: ko-KR-Chirp3-HD-Leda, ko-KR-Chirp3-HD-Puck 등
TTS_GOOGLE_VOICE=ko-KR-Chirp3-HD-Leda

# ============================================================================
# Flow Engine 설정
# ============================================================================
FLOWS_DIR=flows
DEFAULT_SITE=coupang
FLOW_CONFIRMATION_REQUIRED=true

# ============================================================================
# 로깅 설정 최고 우선순위로 덮어쓰기
# ============================================================================
LOG_LEVEL=INFO
LOG_CONSOLE_LEVEL=
LOG_FILE_LEVEL=
LOG_DIR=logs
LOG_FILE=ai_server.log
LOG_ROTATE_WHEN=midnight
LOG_ROTATE_INTERVAL=1
LOG_BACKUP_COUNT=7
LOG_ROTATE_UTC=true

# ============================================================================
# APP_ENV별 기본 세트 (APP_ENV=dev|prod)
# ============================================================================
# DEV 기본값
DEV_DEBUG=true
DEV_LOG_LEVEL=DEBUG
DEV_LOG_CONSOLE_LEVEL=DEBUG
DEV_LOG_FILE_LEVEL=INFO
DEV_LOG_DIR=logs
DEV_LOG_FILE=ai_server.log
DEV_LOG_ROTATE_WHEN=midnight
DEV_LOG_ROTATE_INTERVAL=1
DEV_LOG_BACKUP_COUNT=7
DEV_LOG_ROTATE_UTC=true

# PROD 기본값
PROD_DEBUG=false
PROD_LOG_LEVEL=INFO
PROD_LOG_CONSOLE_LEVEL=WARNING
PROD_LOG_FILE_LEVEL=WARNING
PROD_LOG_DIR=logs
PROD_LOG_FILE=ai_server.log
PROD_LOG_ROTATE_WHEN=midnight
PROD_LOG_ROTATE_INTERVAL=1
PROD_LOG_BACKUP_COUNT=30
PROD_LOG_ROTATE_UTC=true

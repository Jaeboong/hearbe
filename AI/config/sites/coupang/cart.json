    "cart_item": "[id^='item_'], .cart-product",
    "item_checkbox": "input[type='checkbox']",
    "item_title": "a span.twc-text-custom-black, .product-name",
    "item_price": "[data-id='sale-price-ccid'], .price, [class*='twc-text-[20px]']",
    "quantity_input": "input.cart-quantity-input, input[type='text']",
    "quantity_plus": "[data-component-id='quantity-input'] .twc-bg-plus-icon",
    "quantity_minus": "[data-component-id='quantity-input'] .twc-bg-minus-icon",
    "delete_button": "button:has-text(\"삭제\"), a:has-text(\"삭제\"), div:has-text(\"삭제\")",
    "delete_selected": "button:has-text(\"선택 삭제\"), a:has-text(\"선택 삭제\"), div:has-text(\"선택 삭제\")",
    "delete_soldout": "[class*='order']:has-text('?덉젅/?먮ℓ醫낅즺?곹뭹 ?꾩껜??젣')",
    "order_estimate_block": "[data-component-id='total-price']",
    "total_product_price": "[data-component-id='total-price'] div:has-text('총 상품 가격') em[translate='no']",
    "total_instant_discount": "[data-component-id='total-price'] div:has-text('총 즉시할인') em[translate='no']",
    "shipping_fee": "[data-component-id='total-price'] div:has-text('총 배송비') em[translate='no']",
    "total_price": "#finalOrderPrice em[translate='no']",
    "final_order_price": "#finalOrderPrice em[translate='no']",

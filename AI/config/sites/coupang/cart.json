    "modal_add_rocket": "[class*='order']:has-text('濡쒖폆?곹뭹 異붽??섍린')",
    "modal_checkout_without_extra": "[class*='order']:has-text('異붽?湲덉븸 ?놁씠 援щℓ?섍린')"
  }
}

{
  "page_type": "cart",
  "url_pattern": "cart\\.coupang\\.com/cartView",
  "description": "쿠팡 장바구니 페이지",
  "selectors": {
    "checkout_button": "#btnPay",
    "select_all_checkbox": "input[type='checkbox']",
    "cart_item_list": "#mainContent, .cart-product-list",
    "cart_item": "[id^='item_'], .cart-product",
    "item_checkbox": "input[type='checkbox']",
    "item_title": "a span.twc-text-custom-black, .product-name",
    "item_price": "[data-id='sale-price-ccid'], .price, [class*='twc-text-[20px]']",
    "quantity_input": "input.cart-quantity-input, input[type='text']",
    "quantity_plus": "[data-component-id='quantity-input'] .twc-bg-plus-icon, button[aria-label*='증가'], button[aria-label*='더하기']",
    "quantity_minus": "[data-component-id='quantity-input'] .twc-bg-minus-icon, button[aria-label*='감소'], button[aria-label*='빼기']",
    "delete_button": ".btn-delete",
    "delete_selected": "[class*='order']:has-text('선택삭제')",
    "delete_soldout": "[class*='order']:has-text('품절/판매종료상품 전체삭제')",
    "total_price": ".total-price",
    "order_steps": "[class*='order']",
    "modal_add_rocket": "[class*='order']:has-text('로켓상품 추가하기')",
    "modal_checkout_without_extra": "[class*='order']:has-text('추가금액 없이 구매하기')"
  }
}

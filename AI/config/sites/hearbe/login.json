{
  "page_type": "login",
  "url_pattern": "/[ABC]/login",
  "description": "Hearbe login page",
  "selectors": {
    "id_input": "input[type='text'][placeholder*='아이디']",
    "email_input": "input[type='text'][placeholder*='아이디']",
    "password_input": "input[placeholder*='비밀번호']",
    "login_button": "button[type='submit']:has-text('로그인')",
    "submit_button": "button[type='submit']:has-text('로그인')",
    "remember_me_checkbox": "input[type='checkbox']#rememberLogin, input[type='checkbox'][id*='remember' i]"
  }
}

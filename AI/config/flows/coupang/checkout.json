{
    "flow_id": "coupang_checkout",
    "flow_type": "checkout",
    "site": "coupang",
    "total_steps": 6,
    "steps": [
        {
            "step_id": 1,
            "name": "cart_confirm",
            "prompt": "장바구니에 {product_name}이(가) 담겨있습니다. 가격은 {price}원입니다. 결제를 진행할까요?",
            "required_fields": ["product_name", "price"],
            "user_confirmation": true,
            "action": null,
            "fallback": "알겠습니다. 결제를 취소합니다.",
            "next_step": 2
        },
        {
            "step_id": 2,
            "name": "go_to_checkout",
            "prompt": "결제 페이지로 이동합니다.",
            "action": {
                "tool_name": "click_element",
                "arguments": {
                    "selector": ".checkout-btn, .order-btn"
                }
            },
            "validation": {
                "type": "selector_exists",
                "selector": ".order-sheet, .checkout-page"
            },
            "fallback": "결제 페이지로 이동하지 못했습니다. 다시 시도할까요?",
            "next_step": 3
        },
        {
            "step_id": 3,
            "name": "address_confirm",
            "prompt": "배송지를 확인해주세요. {address}로 배송됩니다. 맞으시면 '네'라고 말씀해주세요.",
            "required_fields": ["address"],
            "user_confirmation": true,
            "action": null,
            "fallback": "배송지를 변경하시겠습니까?",
            "next_step": 4
        },
        {
            "step_id": 4,
            "name": "payment_method_select",
            "prompt": "결제 수단을 선택해주세요. 카드, 계좌이체, 간편결제 중 어떤 것으로 하시겠어요?",
            "required_fields": ["payment_method"],
            "user_confirmation": false,
            "action": null,
            "next_step": 5
        },
        {
            "step_id": 5,
            "name": "final_confirm",
            "prompt": "최종 결제 금액은 {total_price}원입니다. {product_name}을(를) {address}로 배송합니다. 결제를 진행할까요?",
            "required_fields": ["total_price", "product_name", "address"],
            "user_confirmation": true,
            "action": null,
            "fallback": "결제를 취소합니다.",
            "next_step": 6
        },
        {
            "step_id": 6,
            "name": "complete_payment",
            "prompt": "결제가 완료되었습니다. 주문 내역은 마이페이지에서 확인하실 수 있습니다.",
            "action": {
                "tool_name": "click_element",
                "arguments": {
                    "selector": ".pay-btn, .order-submit"
                }
            },
            "validation": {
                "type": "selector_exists",
                "selector": ".order-complete, .success"
            },
            "fallback": "결제 처리 중 문제가 발생했습니다."
        }
    ]
}

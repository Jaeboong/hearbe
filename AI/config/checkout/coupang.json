{
    "site": "coupang",
    "name": "쿠팡 결제",
    "steps": [
        {
            "id": "start_checkout",
            "name": "결제 시작",
            "description": "장바구니에서 결제 페이지로 이동",
            "actions": [
                {
                    "action": "click",
                    "selector": ".prod-buy-btn__txt",
                    "fallback_text": "구매하기"
                },
                {
                    "action": "wait",
                    "ms": 2000
                }
            ],
            "prompt": "결제를 시작합니다."
        },
        {
            "id": "confirm_address",
            "name": "배송지 확인",
            "description": "배송지 정보 확인",
            "actions": [
                {
                    "action": "wait_for",
                    "selector": ".address-component"
                },
                {
                    "action": "click",
                    "selector": ".address-select-btn",
                    "fallback_text": "선택",
                    "optional": true
                }
            ],
            "prompt": "배송지를 확인해 주세요.",
            "wait_for_user": false
        },
        {
            "id": "select_payment",
            "name": "결제 수단",
            "description": "결제 수단 선택",
            "actions": [
                {
                    "action": "click",
                    "selector": ".payment-method-card",
                    "fallback_text": "카드결제"
                }
            ],
            "prompt": "결제 수단을 선택해 주세요. 카드결제로 진행하겠습니다.",
            "options": [
                {
                    "name": "카드결제",
                    "selector": ".payment-method-card"
                },
                {
                    "name": "간편결제",
                    "selector": ".payment-method-easy"
                },
                {
                    "name": "무통장",
                    "selector": ".payment-method-transfer"
                }
            ]
        },
        {
            "id": "final_payment",
            "name": "최종 결제",
            "description": "결제 확인 및 완료",
            "actions": [
                {
                    "action": "click",
                    "selector": "button.checkout-submit",
                    "fallback_text": "결제하기"
                }
            ],
            "prompt": "결제를 진행하시겠습니까?",
            "requires_confirmation": true
        }
    ],
    "selectors": {
        "cart_checkout_btn": "button.order-btn",
        "address_section": ".address-component",
        "payment_section": ".payment-method-wrap",
        "final_checkout_btn": "button.checkout-submit",
        "total_price": ".total-price .price-value"
    }
}